<?xml version="1.0" encoding="UTF-8"?>
<!--
=====================================================================
  IIS web.config for SF Portal
  對齊主管圖 + Z 方案要求

  功能:
  - 反向代理: HTTPS 443 → Flask Portal (waitress 127.0.0.1:5000)
  - TLS / HSTS / Security Headers Hardening
  - 靜態檔案直接走 IIS, 動態走 Flask
  - 隱藏 server 版本資訊
  - 阻擋 HTTP 改導 HTTPS

  套用位置: C:\inetpub\wwwroot\Portal\web.config
  或: D:\DataExchange\_portal\app\web.config (Portal 應用程式目錄)

  需要先裝: URL Rewrite 2.1 + Application Request Routing 3.0
=====================================================================
-->
<configuration>

  <system.webServer>

    <!-- ===== Security Headers (對齊 SSL Labs A+ / 金融業 Hardening) ===== -->
    <httpProtocol>
      <customHeaders>
        <!-- 隱藏 IIS 版本 -->
        <remove name="X-Powered-By" />

        <!-- HSTS: 強制 HTTPS, 2 年 -->
        <add name="Strict-Transport-Security" value="max-age=63072000; includeSubDomains" />

        <!-- 防 clickjacking -->
        <add name="X-Frame-Options" value="DENY" />

        <!-- 防 MIME sniffing -->
        <add name="X-Content-Type-Options" value="nosniff" />

        <!-- XSS 防護 (舊瀏覽器) -->
        <add name="X-XSS-Protection" value="1; mode=block" />

        <!-- Referrer Policy -->
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />

        <!-- Content Security Policy (Portal 內部使用, 嚴格) -->
        <add name="Content-Security-Policy" value="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' fonts.googleapis.com; font-src 'self' fonts.gstatic.com; img-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'" />

        <!-- Permissions Policy -->
        <add name="Permissions-Policy" value="geolocation=(), microphone=(), camera=(), payment=()" />
      </customHeaders>
    </httpProtocol>

    <!-- ===== 移除預設 Banner (回應 header 不顯 server) ===== -->
    <security>
      <requestFiltering removeServerHeader="true">
        <!-- 阻擋常見惡意路徑 -->
        <fileExtensions>
          <add fileExtension=".bak" allowed="false" />
          <add fileExtension=".config" allowed="false" />
          <add fileExtension=".db" allowed="false" />
          <add fileExtension=".env" allowed="false" />
          <add fileExtension=".log" allowed="false" />
          <add fileExtension=".sql" allowed="false" />
          <add fileExtension=".py" allowed="false" />
        </fileExtensions>
        <hiddenSegments>
          <add segment=".git" />
          <add segment=".venv" />
          <add segment="__pycache__" />
          <add segment="node_modules" />
        </hiddenSegments>
        <!-- 限制請求大小 (上傳檔案改走 SFTP, Portal 上傳僅小檔簽核附件) -->
        <requestLimits maxAllowedContentLength="104857600" />  <!-- 100 MB -->
      </requestFiltering>
    </security>

    <!-- ===== 關閉 Directory Browsing (對齊 Hardening) ===== -->
    <directoryBrowse enabled="false" />

    <!-- ===== Default Documents (預設首頁) ===== -->
    <defaultDocument>
      <files>
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>

    <!-- ===== 反向代理 (Flask Portal on 127.0.0.1:5000) ===== -->
    <!-- 需要先安裝 URL Rewrite 2.1 + ARR 3.0 -->
    <rewrite>
      <rules>

        <!-- 規則 1: 靜態檔案直接走 IIS (避免反代) -->
        <rule name="StaticContent" stopProcessing="true">
          <match url="^static/(.*)$" />
          <action type="None" />
        </rule>

        <!-- 規則 2: HTTP 強制導向 HTTPS -->
        <rule name="RedirectToHTTPS" stopProcessing="true">
          <match url=".*" />
          <conditions>
            <add input="{HTTPS}" pattern="off" ignoreCase="true" />
          </conditions>
          <action type="Redirect" url="https://{HTTP_HOST}/{R:0}" redirectType="Permanent" />
        </rule>

        <!-- 規則 3: 反向代理到 Flask -->
        <rule name="ReverseProxyToFlask" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <add input="{HTTPS}" pattern="on" />
          </conditions>
          <serverVariables>
            <set name="HTTP_X_FORWARDED_PROTO" value="https" />
            <set name="HTTP_X_FORWARDED_FOR" value="{REMOTE_ADDR}" />
            <set name="HTTP_X_REAL_IP" value="{REMOTE_ADDR}" />
          </serverVariables>
          <action type="Rewrite" url="http://127.0.0.1:5000/{R:1}" />
        </rule>

      </rules>

      <!-- 允許 outbound 改寫 (給 Flask 回的 Location header 改成 HTTPS) -->
      <outboundRules>
        <rule name="FixLocationHeader" preCondition="ResponseIsRedirect">
          <match serverVariable="RESPONSE_LOCATION" pattern="^http://127.0.0.1:5000/(.*)" />
          <action type="Rewrite" value="https://{HTTP_HOST}/{R:1}" />
        </rule>
        <preConditions>
          <preCondition name="ResponseIsRedirect">
            <add input="{RESPONSE_STATUS}" pattern="^3\d\d$" />
          </preCondition>
        </preConditions>
      </outboundRules>
    </rewrite>

    <!-- ===== ARR Proxy 開關 (machine-level 開啟後此處 enabled=true) ===== -->
    <!-- 注意: ARR proxy 是 server-level 設定, 部署時還要在 IIS Manager 開啟 -->
    <proxy enabled="true" preserveHostHeader="true" reverseRewriteHostInResponseHeaders="false" />

    <!-- ===== 壓縮 ===== -->
    <urlCompression doStaticCompression="true" doDynamicCompression="true" />

    <!-- ===== HTTP Errors (不顯詳細錯誤訊息, 避免資訊洩漏) ===== -->
    <httpErrors errorMode="DetailedLocalOnly" />

    <!-- ===== 連線限制 (反 DoS, 中型 SF 主機適用) ===== -->
    <serverRuntime appConcurrentRequestLimit="500" />

  </system.webServer>

  <!-- ===== .NET 設定 (即使是 Flask 不走 .NET, 也設一下安全防護) ===== -->
  <system.web>
    <httpRuntime maxRequestLength="102400" executionTimeout="300" />
    <customErrors mode="On" />
    <compilation debug="false" />
    <trace enabled="false" />
  </system.web>

</configuration>
