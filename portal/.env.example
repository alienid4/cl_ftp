# SF Portal 環境變數範本
# 部署時複製為 .env, 填入實際值

# ===== Flask =====
FLASK_ENV=production
SECRET_KEY=<請改為 32+ 字元的隨機字串>
SESSION_TIMEOUT_MIN=30

# ===== DB =====
# 第一階段 (Express 本機)
DB_MODE=Express
DB_CONNECTION_STRING=Server=.\SQLEXPRESS;Database=FileExchangeAudit;Trusted_Connection=yes;TrustServerCertificate=yes

# 第二階段 (公司 DB) — 切過去時改成這個
# DB_MODE=CorpDB
# DB_CONNECTION_STRING=Server=corp-sql01.internal,1433;Database=FileExchangeAudit;Trusted_Connection=yes;TrustServerCertificate=yes

# ===== AD / LDAP =====
AD_SERVER=ldap://corp-dc01.corp.local
AD_BASE_DN=DC=corp,DC=local
AD_DOMAIN=CORP
# Portal 用的服務帳號 (查 AD 群組成員時用, 不存個人密碼)
AD_BIND_USER=CORP\svc_portal_ldap
AD_BIND_PASS=<請從 PAM 或安全管道取得>

# ===== Mail =====
SMTP_SERVER=mail-relay.corp.local
SMTP_PORT=25
SMTP_USE_TLS=false
SMTP_FROM=sf-noreply@corp.local
ADMIN_EMAIL=it-admin@corp.local

# ===== File paths =====
DATA_EXCHANGE_ROOT=D:\DataExchange
PORTAL_LOG_DIR=D:\_portal\logs
PORTAL_BACKUP_DIR=D:\_portal\backups

# ===== Batch 邏輯 =====
BATCH_IDLE_SECONDS=30                # 滑動窗口
BATCH_SAFETY_MINUTES=5               # 安全閥
APPROVAL_TIMEOUT_DAYS=7              # 簽核超時

# ===== 保留期 =====
HOME_RETENTION_DAYS=7
SAMBA_RETENTION_DAYS=7
AUDITLOG_ONLINE_DAYS=365
AUDITLOG_ARCHIVE_YEARS=5

# ===== Debug =====
DEBUG=false
VERBOSE_LOG=false
